{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agenticos.control.workflow_definition.v1",
  "title": "AgenticOS Workflow Definition v1",
  "type": "object",
  "$defs": {
    "taskNode": {
      "type": "object",
      "required": ["id", "prompt"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "role": {"type": ["string", "null"]},
        "prompt": {"type": "string", "minLength": 1},
        "workload": {"type": ["string", "null"]},
        "backend_class": {"type": ["string", "null"]},
        "context_strategy": {"type": ["string", "null"]},
        "context_window_size": {"type": ["integer", "null"], "minimum": 1},
        "context_trigger_tokens": {"type": ["integer", "null"], "minimum": 1},
        "context_target_tokens": {"type": ["integer", "null"], "minimum": 1},
        "context_retrieve_top_k": {"type": ["integer", "null"], "minimum": 1},
        "trust_scope": {"type": ["string", "null"]},
        "allow_actions": {"type": ["boolean", "null"]},
        "allowed_tools": {
          "type": ["array", "null"],
          "items": {"type": "string", "minLength": 1}
        },
        "path_scopes": {
          "type": ["array", "null"],
          "items": {"type": "string", "minLength": 1}
        },
        "deps": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        }
      }
    }
  },
  "required": ["tasks"],
  "properties": {
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/taskNode"}
    },
    "failure_policy": {
      "type": "string",
      "enum": ["fail_fast", "best_effort"]
    }
  }
}
