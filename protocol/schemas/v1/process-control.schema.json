{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agenticos.control.process_control.v1",
  "title": "AgenticOS TERM/KILL Responses v1",
  "allOf": [
    {"$ref": "./control-envelope.schema.json"},
    {
      "properties": {
        "schema_id": {"enum": ["agenticos.control.term.v1", "agenticos.control.kill.v1"]},
        "data": {
          "type": "object",
          "required": ["pid", "status", "mode"],
          "properties": {
            "pid": {"type": "integer", "minimum": 0},
            "status": {"type": "string"},
            "mode": {"type": "string"}
          },
          "additionalProperties": false
        }
      }
    }
  ]
}
