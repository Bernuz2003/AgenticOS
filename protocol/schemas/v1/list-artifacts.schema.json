{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agenticos.control.list_artifacts.v1",
  "title": "AgenticOS LIST_ARTIFACTS Response v1",
  "$defs": {
    "artifact": {
      "type": "object",
      "required": [
        "artifact_id",
        "task",
        "attempt",
        "kind",
        "label",
        "mime_type",
        "preview",
        "content",
        "bytes",
        "created_at_ms"
      ],
      "properties": {
        "artifact_id": {"type": "string", "minLength": 1},
        "task": {"type": "string", "minLength": 1},
        "attempt": {"type": "integer", "minimum": 1},
        "kind": {"type": "string", "minLength": 1},
        "label": {"type": "string", "minLength": 1},
        "mime_type": {"type": "string", "minLength": 1},
        "preview": {"type": "string"},
        "content": {"type": "string"},
        "bytes": {"type": "integer", "minimum": 0},
        "created_at_ms": {"type": "integer"}
      }
    }
  },
  "allOf": [
    {"$ref": "./control-envelope.schema.json"},
    {
      "properties": {
        "schema_id": {"const": "agenticos.control.list_artifacts.v1"},
        "data": {
          "type": "object",
          "required": ["orchestration_id", "task", "artifacts"],
          "properties": {
            "orchestration_id": {"type": "integer", "minimum": 1},
            "task": {"type": ["string", "null"]},
            "artifacts": {
              "type": "array",
              "items": {"$ref": "#/$defs/artifact"}
            }
          }
        }
      }
    }
  ]
}
