{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agenticos.control.error.v1",
  "title": "AgenticOS Error Envelope v1",
  "allOf": [
    {"$ref": "./control-envelope.schema.json"},
    {
      "properties": {
        "schema_id": {"const": "agenticos.control.error.v1"},
        "ok": {"const": false},
        "data": {"type": "null"},
        "error": {
          "type": "object",
          "required": ["message"],
          "properties": {
            "message": {"type": "string", "minLength": 1}
          },
          "additionalProperties": true
        }
      },
      "required": ["error"]
    }
  ]
}