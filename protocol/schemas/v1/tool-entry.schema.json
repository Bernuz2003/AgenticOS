{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agenticos.control.tool_entry.v1",
  "title": "AgenticOS Tool Registry Entry v1",
  "type": "object",
  "required": ["descriptor", "backend"],
  "properties": {
    "descriptor": {
      "type": "object",
      "required": [
        "name",
        "aliases",
        "description",
        "input_schema",
        "output_schema",
        "allowed_callers",
        "backend_kind",
        "capabilities",
        "dangerous",
        "enabled",
        "default_allowlisted",
        "approval_required",
        "source"
      ],
      "properties": {
        "name": {"type": "string"},
        "aliases": {"type": "array", "items": {"type": "string"}},
        "description": {"type": "string"},
        "input_schema": {"type": "object"},
        "input_example": {},
        "output_schema": {"type": "object"},
        "allowed_callers": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["agent_text", "agent_supervisor", "programmatic", "control_plane"]
          }
        },
        "backend_kind": {"type": "string", "enum": ["host", "wasm", "remote_http"]},
        "capabilities": {"type": "array", "items": {"type": "string"}},
        "dangerous": {"type": "boolean"},
        "enabled": {"type": "boolean"},
        "default_allowlisted": {"type": "boolean"},
        "approval_required": {"type": "boolean"},
        "interop": {
          "type": ["object", "null"],
          "required": [
            "provider",
            "server_id",
            "transport",
            "target_name",
            "trust_level",
            "auth_mode",
            "default_allowlisted",
            "approval_required",
            "hints"
          ],
          "properties": {
            "provider": {"type": "string"},
            "server_id": {"type": "string"},
            "server_label": {"type": ["string", "null"]},
            "transport": {"type": "string"},
            "target_name": {"type": "string"},
            "trust_level": {"type": "string"},
            "auth_mode": {"type": "string"},
            "default_allowlisted": {"type": "boolean"},
            "approval_required": {"type": "boolean"},
            "hints": {
              "type": "object",
              "properties": {
                "title": {"type": ["string", "null"]},
                "read_only_hint": {"type": "boolean"},
                "destructive_hint": {"type": "boolean"},
                "idempotent_hint": {"type": "boolean"},
                "open_world_hint": {"type": "boolean"}
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        "source": {"type": "string", "enum": ["built_in", "runtime"]}
      },
      "additionalProperties": false
    },
    "backend": {
      "oneOf": [
        {
          "type": "object",
          "required": ["kind", "executor"],
          "properties": {
            "kind": {"const": "host"},
            "executor": {"type": "string", "minLength": 1}
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["kind", "module", "export"],
          "properties": {
            "kind": {"const": "wasm"},
            "module": {"type": "string", "minLength": 1},
            "export": {"type": "string", "minLength": 1}
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["kind", "url", "method", "timeout_ms", "headers"],
          "properties": {
            "kind": {"const": "remote_http"},
            "url": {"type": "string", "minLength": 1},
            "method": {"type": "string", "minLength": 1},
            "timeout_ms": {"type": "integer", "minimum": 1},
            "headers": {
              "type": "object",
              "additionalProperties": {"type": "string"}
            }
          },
          "additionalProperties": false
        }
      ]
    }
  },
  "additionalProperties": false
}
