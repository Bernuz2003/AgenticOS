{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agenticos.control.list_tools.v1",
  "title": "AgenticOS LIST_TOOLS Response v1",
  "allOf": [
    {"$ref": "./control-envelope.schema.json"},
    {
      "properties": {
        "schema_id": {"const": "agenticos.control.list_tools.v1"},
        "data": {
          "type": "object",
          "required": ["total_tools", "tools"],
          "properties": {
            "total_tools": {"type": "integer", "minimum": 0},
            "tools": {
              "type": "array",
              "items": {"$ref": "./tool-entry.schema.json"}
            }
          },
          "additionalProperties": false
        }
      }
    }
  ]
}
