{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agenticos.control.register_tool.v1",
  "title": "AgenticOS REGISTER_TOOL Response v1",
  "allOf": [
    {"$ref": "./control-envelope.schema.json"},
    {
      "properties": {
        "schema_id": {"const": "agenticos.control.register_tool.v1"},
        "data": {
          "type": "object",
          "required": ["tool"],
          "properties": {
            "tool": {
              "type": "object",
              "required": ["descriptor", "backend"],
              "properties": {
                "descriptor": {
                  "type": "object",
                  "required": [
                    "name",
                    "aliases",
                    "description",
                    "input_schema",
                    "output_schema",
                    "backend_kind",
                    "capabilities",
                    "dangerous",
                    "enabled",
                    "source"
                  ],
                  "properties": {
                    "name": {"type": "string"},
                    "aliases": {"type": "array", "items": {"type": "string"}},
                    "description": {"type": "string"},
                    "input_schema": {"type": "object"},
                    "output_schema": {"type": "object"},
                    "backend_kind": {"type": "string", "enum": ["host", "wasm", "remote_http"]},
                    "capabilities": {"type": "array", "items": {"type": "string"}},
                    "dangerous": {"type": "boolean"},
                    "enabled": {"type": "boolean"},
                    "source": {"type": "string", "enum": ["built_in", "runtime"]}
                  },
                  "additionalProperties": false
                },
                "backend": {
                  "oneOf": [
                    {
                      "type": "object",
                      "required": ["kind", "executor"],
                      "properties": {
                        "kind": {"const": "host"},
                        "executor": {"type": "string", "minLength": 1}
                      },
                      "additionalProperties": false
                    },
                    {
                      "type": "object",
                      "required": ["kind", "module", "export"],
                      "properties": {
                        "kind": {"const": "wasm"},
                        "module": {"type": "string", "minLength": 1},
                        "export": {"type": "string", "minLength": 1}
                      },
                      "additionalProperties": false
                    },
                    {
                      "type": "object",
                      "required": ["kind", "url", "method", "timeout_ms", "headers"],
                      "properties": {
                        "kind": {"const": "remote_http"},
                        "url": {"type": "string", "minLength": 1},
                        "method": {"type": "string", "minLength": 1},
                        "timeout_ms": {"type": "integer", "minimum": 1},
                        "headers": {
                          "type": "object",
                          "additionalProperties": {"type": "string"}
                        }
                      },
                      "additionalProperties": false
                    }
                  ]
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      }
    }
  ]
}