{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agenticos.control.exec.v1",
  "title": "AgenticOS EXEC Response v1",
  "allOf": [
    {"$ref": "./control-envelope.schema.json"},
    {
      "properties": {
        "schema_id": {"const": "agenticos.control.exec.v1"},
        "data": {
          "type": "object",
          "required": ["session_id", "pid", "workload", "priority"],
          "properties": {
            "session_id": {"type": "string", "minLength": 1},
            "pid": {"type": "integer", "minimum": 0},
            "workload": {"type": "string"},
            "priority": {"type": "string"},
            "context_strategy": {"type": "string"},
            "context_window_size": {"type": "integer", "minimum": 1}
          },
          "additionalProperties": false
        }
      }
    }
  ]
}
