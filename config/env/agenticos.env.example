# Copy to config/env/agenticos.env and fill with your real local secrets.
# This file is gitignored.

AGENTIC_OPENAI_API_KEY="replace-me"
AGENTIC_GROQ_API_KEY="replace-me"
AGENTIC_OPENROUTER_API_KEY="replace-me"

# Remote tool policy.
# Exact-match host allowlist, comma-separated, lowercase.
AGENTIC_REMOTE_TOOL_ALLOWED_HOSTS="www.agno.com,agno.com,api.duckduckgo.com"

# Guardrails for remote built-in tools.
AGENTIC_REMOTE_TOOL_MAX_REQUEST_BYTES="16384"
AGENTIC_REMOTE_TOOL_MAX_RESPONSE_BYTES="262144"

# Optional: override the JSON provider used by web_search.
# AGENTIC_WEB_SEARCH_BASE_URL="https://api.duckduckgo.com/"
