# Copy this file to config/kernel/local.toml for machine-local overrides that should not be pushed.
# Keep secrets in config/env/agenticos.env whenever possible.

[external_llamacpp]
# Optional machine-local override if `llama-server` is not on PATH.
executable = "/usr/local/bin/llama-server"

[openrouter]
http_referer = "http://localhost"
app_title = "AgenticOS"

[tools]
# Alternative to the env vars above when you prefer machine-local TOML overrides.
remote_http_allowed_hosts = ["www.agno.com", "agno.com", "api.duckduckgo.com"]
remote_http_max_request_bytes = 16384
remote_http_max_response_bytes = 262144

[mcp]
# Edge MCP interop stays disabled by default.
enabled = false

[[mcp.servers]]
# Example: official filesystem MCP server over stdio.
# Requires a local Node.js + `npx` install and an explicit allowed root path.
id = "filesystem"
label = "Filesystem MCP"
enabled = false
tool_prefix = "fs"
exposed_tools = []
default_allowlisted = false
approval_required = true
roots_enabled = true
trust_level = "trusted"

[mcp.servers.transport]
kind = "stdio"
command = "npx"
args = [
  "-y",
  "@modelcontextprotocol/server-filesystem",
  "/absolute/path/to/allowed/workspace",
]
cwd = "../.."
timeout_ms = 10000
