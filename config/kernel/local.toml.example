# Copy this file to config/kernel/local.toml for machine-local overrides that should not be pushed.
# Keep secrets in config/env/agenticos.env whenever possible.

[external_llamacpp]
# Optional machine-local override if `llama-server` is not on PATH.
executable = "/usr/local/bin/llama-server"

[openrouter]
http_referer = "http://localhost"
app_title = "AgenticOS"
