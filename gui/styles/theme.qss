/* AgenticOS — Dark Professional Theme (Tokyo Night inspired) */

/* ── Global ─────────────────────────────────────────────────── */

QWidget {
    background-color: #1a1b26;
    color: #c0caf5;
    font-family: "Segoe UI", "Ubuntu", "Noto Sans", sans-serif;
    font-size: 13px;
}

QMainWindow {
    background-color: #1a1b26;
}

/* ── Sidebar ────────────────────────────────────────────────── */

QWidget#sidebar {
    background-color: #16161e;
    border-right: 1px solid #3b4261;
}

QPushButton#nav_button {
    background-color: transparent;
    color: #565f89;
    border: none;
    border-radius: 6px;
    padding: 10px 16px;
    text-align: left;
    font-size: 13px;
    font-weight: 500;
}

QPushButton#nav_button:hover {
    background-color: #24283b;
    color: #c0caf5;
}

QPushButton#nav_button[active="true"] {
    background-color: #24283b;
    color: #7aa2f7;
    border-left: 3px solid #7aa2f7;
    font-weight: 600;
}

QLabel#sidebar_title {
    color: #7aa2f7;
    font-size: 16px;
    font-weight: 700;
    padding: 8px 0;
}

QLabel#mini_status_label {
    color: #565f89;
    font-size: 11px;
}

QLabel#mini_status_value {
    color: #c0caf5;
    font-size: 11px;
    font-weight: 600;
}

QLabel#status_online {
    color: #9ece6a;
    font-weight: 600;
}

QLabel#status_offline {
    color: #f7768e;
    font-weight: 600;
}

/* ── Buttons ────────────────────────────────────────────────── */

QPushButton {
    background-color: #24283b;
    color: #c0caf5;
    border: 1px solid #3b4261;
    border-radius: 6px;
    padding: 6px 14px;
    font-weight: 500;
}

QPushButton:hover {
    background-color: #3b4261;
    border-color: #7aa2f7;
}

QPushButton:pressed {
    background-color: #1f2335;
}

QPushButton:disabled {
    background-color: #1f2335;
    color: #565f89;
    border-color: #24283b;
}

QPushButton#primary_button {
    background-color: #7aa2f7;
    color: #1a1b26;
    border: none;
    font-weight: 600;
}

QPushButton#primary_button:hover {
    background-color: #89b4fa;
}

QPushButton#primary_button:pressed {
    background-color: #6a92e7;
}

QPushButton#danger_button {
    background-color: #f7768e;
    color: #1a1b26;
    border: none;
    font-weight: 600;
}

QPushButton#danger_button:hover {
    background-color: #ff899e;
}

QPushButton#start_button {
    background-color: #9ece6a;
    color: #1a1b26;
    border: none;
    font-weight: 600;
}

QPushButton#start_button:hover {
    background-color: #b0de7a;
}

QPushButton#stop_button {
    background-color: #e0af68;
    color: #1a1b26;
    border: none;
    font-weight: 600;
}

QPushButton#stop_button:hover {
    background-color: #f0bf78;
}

/* ── Input Fields ───────────────────────────────────────────── */

QLineEdit, QSpinBox, QDoubleSpinBox {
    background-color: #1f2335;
    color: #c0caf5;
    border: 1px solid #3b4261;
    border-radius: 4px;
    padding: 5px 8px;
    selection-background-color: #7aa2f7;
    selection-color: #1a1b26;
}

QLineEdit:focus, QSpinBox:focus, QDoubleSpinBox:focus {
    border-color: #7aa2f7;
}

QTextEdit, QPlainTextEdit {
    background-color: #1f2335;
    color: #c0caf5;
    border: 1px solid #3b4261;
    border-radius: 6px;
    padding: 8px;
    selection-background-color: #7aa2f7;
    selection-color: #1a1b26;
}

QTextBrowser {
    background-color: #1f2335;
    color: #c0caf5;
    border: 1px solid #3b4261;
    border-radius: 6px;
    padding: 8px;
}

/* ── Combo Box ──────────────────────────────────────────────── */

QComboBox {
    background-color: #1f2335;
    color: #c0caf5;
    border: 1px solid #3b4261;
    border-radius: 4px;
    padding: 5px 8px;
    min-width: 120px;
}

QComboBox:hover {
    border-color: #7aa2f7;
}

QComboBox::drop-down {
    border: none;
    width: 24px;
}

QComboBox QAbstractItemView {
    background-color: #24283b;
    color: #c0caf5;
    border: 1px solid #3b4261;
    selection-background-color: #7aa2f7;
    selection-color: #1a1b26;
}

/* ── Check Box ──────────────────────────────────────────────── */

QCheckBox {
    color: #c0caf5;
    spacing: 6px;
}

QCheckBox::indicator {
    width: 16px;
    height: 16px;
    border: 1px solid #3b4261;
    border-radius: 3px;
    background-color: #1f2335;
}

QCheckBox::indicator:checked {
    background-color: #7aa2f7;
    border-color: #7aa2f7;
}

/* ── Group Box ──────────────────────────────────────────────── */

QGroupBox {
    color: #7aa2f7;
    border: 1px solid #3b4261;
    border-radius: 8px;
    margin-top: 12px;
    padding-top: 16px;
    font-weight: 600;
}

QGroupBox::title {
    subcontrol-origin: margin;
    left: 12px;
    padding: 0 6px;
}

/* ── Scroll Areas ───────────────────────────────────────────── */

QScrollBar:vertical {
    background: #1a1b26;
    width: 8px;
    margin: 0;
}

QScrollBar::handle:vertical {
    background: #3b4261;
    border-radius: 4px;
    min-height: 30px;
}

QScrollBar::handle:vertical:hover {
    background: #565f89;
}

QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0;
}

QScrollBar:horizontal {
    background: #1a1b26;
    height: 8px;
    margin: 0;
}

QScrollBar::handle:horizontal {
    background: #3b4261;
    border-radius: 4px;
    min-width: 30px;
}

QScrollBar::handle:horizontal:hover {
    background: #565f89;
}

QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal {
    width: 0;
}

/* ── Tab Widget ─────────────────────────────────────────────── */

QTabWidget::pane {
    border: 1px solid #3b4261;
    border-radius: 6px;
    background-color: #1a1b26;
}

QTabBar::tab {
    background-color: #16161e;
    color: #565f89;
    border: 1px solid #3b4261;
    border-bottom: none;
    border-top-left-radius: 6px;
    border-top-right-radius: 6px;
    padding: 6px 16px;
    margin-right: 2px;
}

QTabBar::tab:selected {
    background-color: #1a1b26;
    color: #7aa2f7;
    font-weight: 600;
}

QTabBar::tab:hover {
    color: #c0caf5;
}

/* ── Splitter ───────────────────────────────────────────────── */

QSplitter::handle {
    background-color: #3b4261;
}

QSplitter::handle:horizontal {
    width: 2px;
}

QSplitter::handle:vertical {
    height: 2px;
}

/* ── Labels ─────────────────────────────────────────────────── */

QLabel#section_title {
    color: #c0caf5;
    font-size: 18px;
    font-weight: 700;
    padding-bottom: 4px;
}

QLabel#section_subtitle {
    color: #565f89;
    font-size: 12px;
}

QLabel#card_title {
    color: #c0caf5;
    font-size: 14px;
    font-weight: 600;
}

QLabel#card_detail {
    color: #565f89;
    font-size: 12px;
}

QLabel#badge_loaded {
    background-color: #9ece6a;
    color: #1a1b26;
    border-radius: 4px;
    padding: 2px 8px;
    font-size: 11px;
    font-weight: 700;
}

QLabel#badge_available {
    background-color: #3b4261;
    color: #c0caf5;
    border-radius: 4px;
    padding: 2px 8px;
    font-size: 11px;
}

QLabel#badge_loading {
    background-color: #e0af68;
    color: #1a1b26;
    border-radius: 4px;
    padding: 2px 8px;
    font-size: 11px;
    font-weight: 700;
}

/* ── Card Frame ─────────────────────────────────────────────── */

QFrame#card {
    background-color: #24283b;
    border: 1px solid #3b4261;
    border-radius: 8px;
    padding: 12px;
}

QFrame#card:hover {
    border-color: #7aa2f7;
}

/* ── Placeholder Section ────────────────────────────────────── */

QLabel#placeholder_icon {
    color: #3b4261;
    font-size: 48px;
}

QLabel#placeholder_text {
    color: #565f89;
    font-size: 14px;
}

/* ── Tooltip ────────────────────────────────────────────────── */

QToolTip {
    background-color: #24283b;
    color: #c0caf5;
    border: 1px solid #3b4261;
    border-radius: 4px;
    padding: 4px 8px;
}

/* ── Progress Bar ───────────────────────────────────────────── */

QProgressBar {
    background-color: #1f2335;
    border: 1px solid #3b4261;
    border-radius: 4px;
    height: 18px;
    text-align: center;
    color: #c0caf5;
    font-size: 11px;
}

QProgressBar::chunk {
    background-color: #9ece6a;
    border-radius: 3px;
}

/* ── Table Widget ───────────────────────────────────────────── */

QTableWidget {
    background-color: #1f2335;
    alternate-background-color: #24283b;
    border: 1px solid #3b4261;
    border-radius: 6px;
    gridline-color: #3b4261;
    selection-background-color: #7aa2f7;
    selection-color: #1a1b26;
}

QTableWidget::item {
    padding: 4px 8px;
}

QTableWidget::item:selected {
    background-color: #7aa2f7;
    color: #1a1b26;
}

QHeaderView::section {
    background-color: #24283b;
    color: #7aa2f7;
    border: none;
    border-bottom: 2px solid #3b4261;
    border-right: 1px solid #3b4261;
    padding: 5px 8px;
    font-weight: 600;
    font-size: 12px;
}

/* ── Error Banner ───────────────────────────────────────────── */

QLabel#error_banner {
    background-color: #2d202a;
    color: #f7768e;
    border: 1px solid #f7768e;
    border-radius: 6px;
    padding: 6px 12px;
    font-size: 12px;
    font-weight: 500;
}
