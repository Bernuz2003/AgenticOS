{"format":"jsonl-v1","ts_ms":1775056906578,"pid":3,"mode":"Host","caller":"agent_text","transport":"text","tool_call_id":null,"tool_name":"write_file","success":true,"kill":false,"duration_ms":0,"cmd":"TOOL:write_file {\"content\":\"import pygame\\nimport sys\\nimport time\\nimport random\\n\\n# Direzioni\\nUP = 1\\nRIGHT = 2\\nDOWN = 3\\nLEFT = 4\\n\\nclass SnakeGame:\\n    def __init__(self, width=800, height=600):\\n        self.width = width\\n        self.height = height\\n        self.snake = [(200, 200), (220, 200), (240, 200)]\\n        self.direction = RIGHT\\n        self.apple = self.set_new_apple()\\n        self.score = 0\\n        self.game_over = False\\n        pygame.init()\\n        self.display = pygame.display.set_mode((self.width, self.height))\\n        self.font = pygame.font.Font(None, 36)\\n        self.clock = pygame.time.Clock()\\n\\n    def set_new_apple(self):\\n        return (random.randint(0, self.width - 20) // 20 * 20, random.randint(0, self.height - 20) // 20 * 20)\\n\\n    def draw_snake(self):\\n        for x, y in self.snake:\\n            pygame.draw.rect(self.display, (0, 255, 0), (x, y, 20, 20))\\n\\n    def draw_apple(self):\\n        pygame.draw.rect(self.display, (255, 0, 0), (*self.apple, 20, 20))\\n\\n    def update(self):\\n        for event in pygame.event.get():\\n            if event.type == pygame.QUIT:\\n                pygame.quit()\\n                sys.exit()\\n            elif event.type == pygame.KEYDOWN:\\n                if event.key == pygame.K_UP and self.direction != DOWN:\\n                    self.direction = UP\\n                elif event.key == pygame.K_DOWN and self.direction != UP:\\n                    self.direction = DOWN\\n                elif event.key == pygame.K_LEFT and self.direction != RIGHT:\\n                    self.direction = LEFT\\n                elif event.key == pygame.K_RIGHT and self.direction != LEFT:\\n                    self.direction = RIGHT\\n        head = self.snake[-1]\\n        if self.direction == UP:\\n            new_head = (head[0], head[1] - 20)\\n        elif self.direction == DOWN:\\n            new_head = (head[0], head[1] + 20)\\n        elif self.direction == LEFT:\\n            new_head = (head[0] - 20, head[1])\\n        elif self.direction == RIGHT:\\n            new_head = (head[0] + 20, head[1])\\n        self.snake.append(new_head)\\n        if self.snake[-1] == self.apple:\\n            self.score += 1\\n            self.apple = self.set_new_apple()\\n        else:\\n            self.snake.pop(0)\\n        if (self.snake[-1][0] < 0 or self.snake[-1][0] >= self.width or\\n            self.snake[-1][1] < 0 or self.snake[-1][1] >= self.height or\\n            self.snake[-1] in self.snake[:-1]):\\n            self.game_over = True\\n\\n    def draw(self):\\n        self.display.fill((0, 0, 0))\\n        self.draw_snake()\\n        self.draw_apple()\\n        text = self.font.render(f'Score: {self.score}', True, (255, 255, 255))\\n        self.display.blit(text, (10, 10))\\n        pygame.display.flip()\\n\\n    def run(self):\\n        while not self.game_over:\\n            self.update()\\n            self.draw()\\n            self.clock.tick(10)\\n        pygame.quit()\\n\\nif __name__ == '__main__':\\n    game = SnakeGame()\\n    game.run()\",\"path\":\"LLama3.1/snake.py\"}","detail":"Success: File 'LLama3.1/snake.py' written (2909 bytes)."}
{"format":"jsonl-v1","ts_ms":1775056911458,"pid":3,"mode":"Host","caller":"agent_text","transport":"text","tool_call_id":null,"tool_name":"read_file","success":true,"kill":false,"duration_ms":0,"cmd":"TOOL:read_file {\"path\":\"LLama3.1/snake.py\"}","detail":"import pygame\nimport sys\nimport time\nimport random\n\n# Direzioni\nUP = 1\nRIGHT = 2\nDOWN = 3\nLEFT = 4\n\nclass SnakeGame:\n    def __init__(self, width=800, height=600):\n        self.width = width\n        self.height = height\n        self.snake = [(200, 200), (220, 200), (240, 200)]\n        self.direction = RIGHT\n        self.apple = self.set_new_apple()\n        self.score = 0\n        self.game_over = False\n        pygame.init()\n        self.display = pygame.display.set_mode((self.width, self.height))\n        self.font = pygame.font.Font(None, 36)\n        self.clock = pygame.time.Clock()\n\n    def set_new_apple(self):\n        return (random.randint(0, self.width - 20) // 20 * 20, random.randint(0, self.height - 20) // 20 * 20)\n\n    def draw_snake(self):\n        for x, y in self.snake:\n            pygame.draw.rect(self.display, (0, 255, 0), (x, y, 20, 20))\n\n    def draw_apple(self):\n        pygame.draw.rect(self.display, (255, 0, 0), (*self.apple, 20, 20))\n\n    def update(self):\n        for event in pygame.event.get():\n            if event.type == pygame.QUIT:\n                pygame.quit()\n                sys.exit()\n            elif event.type == pygame.KEYDOWN:\n                if event.key == pygame.K_UP and self.direction != DOWN:\n                    self.direction = UP\n                elif event.key == pygame.K_DOWN and self.direction != UP:\n                    self.direction = DOWN\n                elif event.key == pygame.K_LEFT and self.direction != RIGHT:\n                    self.direction = LEFT\n                elif event.key == pygame.K_RIGHT and self.direction != LEFT:\n                    self.direction = RIGHT\n        head = self.snake[-1]\n        if self.direction == UP:\n            new_head = (head[0], head[1] - 20)\n        elif self.direction == DOWN:\n            new_head = (head[0], head[1] + 20)\n        elif self.direction == LEFT:\n            new_head = (head[0] - 20, head[1])\n        elif self.direction == RIGHT:\n            new_head = (head[0] + 20, head[1])\n        self.snake.append(new_head)\n        if self.snake[-1] == self.apple:\n            self.score += 1\n            self.apple = self.set_new_apple()\n        else:\n            self.snake.pop(0)\n        if (self.snake[-1][0] < 0 or self.snake[-1][0] >= self.width or\n            self.snake[-1][1] < 0 or self.snake[-1][1] >= self.height or\n            self.snake[-1] in self.snake[:-1]):\n            self.game_over = True\n\n    def draw(self):\n        self.display.fill((0, 0, 0))\n        self.draw_snake()\n        self.draw_apple()\n        text = self.font.render(f'Score: {self.score}', True, (255, 255, 255))\n        self.display.blit(text, (10, 10))\n        pygame.display.flip()\n\n    def run(self):\n        while not self.game_over:\n            self.update()\n            self.draw()\n            self.clock.tick(10)\n        pygame.quit()\n\nif __name__ == '__main__':\n    game = SnakeGame()\n    game.run()"}
{"format":"jsonl-v1","ts_ms":1775056918207,"pid":3,"mode":"Host","caller":"agent_text","transport":"text","tool_call_id":null,"tool_name":"read_file","success":true,"kill":false,"duration_ms":0,"cmd":"TOOL:read_file {\"path\":\"LLama3.1/snake.py\"}","detail":"import pygame\nimport sys\nimport time\nimport random\n\n# Direzioni\nUP = 1\nRIGHT = 2\nDOWN = 3\nLEFT = 4\n\nclass SnakeGame:\n    def __init__(self, width=800, height=600):\n        self.width = width\n        self.height = height\n        self.snake = [(200, 200), (220, 200), (240, 200)]\n        self.direction = RIGHT\n        self.apple = self.set_new_apple()\n        self.score = 0\n        self.game_over = False\n        pygame.init()\n        self.display = pygame.display.set_mode((self.width, self.height))\n        self.font = pygame.font.Font(None, 36)\n        self.clock = pygame.time.Clock()\n\n    def set_new_apple(self):\n        return (random.randint(0, self.width - 20) // 20 * 20, random.randint(0, self.height - 20) // 20 * 20)\n\n    def draw_snake(self):\n        for x, y in self.snake:\n            pygame.draw.rect(self.display, (0, 255, 0), (x, y, 20, 20))\n\n    def draw_apple(self):\n        pygame.draw.rect(self.display, (255, 0, 0), (*self.apple, 20, 20))\n\n    def update(self):\n        for event in pygame.event.get():\n            if event.type == pygame.QUIT:\n                pygame.quit()\n                sys.exit()\n            elif event.type == pygame.KEYDOWN:\n                if event.key == pygame.K_UP and self.direction != DOWN:\n                    self.direction = UP\n                elif event.key == pygame.K_DOWN and self.direction != UP:\n                    self.direction = DOWN\n                elif event.key == pygame.K_LEFT and self.direction != RIGHT:\n                    self.direction = LEFT\n                elif event.key == pygame.K_RIGHT and self.direction != LEFT:\n                    self.direction = RIGHT\n        head = self.snake[-1]\n        if self.direction == UP:\n            new_head = (head[0], head[1] - 20)\n        elif self.direction == DOWN:\n            new_head = (head[0], head[1] + 20)\n        elif self.direction == LEFT:\n            new_head = (head[0] - 20, head[1])\n        elif self.direction == RIGHT:\n            new_head = (head[0] + 20, head[1])\n        self.snake.append(new_head)\n        if self.snake[-1] == self.apple:\n            self.score += 1\n            self.apple = self.set_new_apple()\n        else:\n            self.snake.pop(0)\n        if (self.snake[-1][0] < 0 or self.snake[-1][0] >= self.width or\n            self.snake[-1][1] < 0 or self.snake[-1][1] >= self.height or\n            self.snake[-1] in self.snake[:-1]):\n            self.game_over = True\n\n    def draw(self):\n        self.display.fill((0, 0, 0))\n        self.draw_snake()\n        self.draw_apple()\n        text = self.font.render(f'Score: {self.score}', True, (255, 255, 255))\n        self.display.blit(text, (10, 10))\n        pygame.display.flip()\n\n    def run(self):\n        while not self.game_over:\n            self.update()\n            self.draw()\n            self.clock.tick(10)\n        pygame.quit()\n\nif __name__ == '__main__':\n    game = SnakeGame()\n    game.run()"}
{"format":"jsonl-v1","ts_ms":1775056991803,"pid":1,"mode":"Host","caller":"agent_text","transport":"text","tool_call_id":null,"tool_name":"write_file","success":true,"kill":false,"duration_ms":0,"cmd":"TOOL:write_file {\"content\":\"import curses\\nimport random\\n\\nclass SnakeGame:\\n    def __init__(self):\\n        self.stdscr = None\\n        self.snake = []\\n        self.food = None\\n        self.direction = curses.KEY_RIGHT\\n        self.score = 0\\n        self.running = True\\n\\n    def setup(self, stdscr):\\n        self.stdscr = stdscr\\n        self.stdscr.clear()\\n        self.stdscr.nodelay(1)\\n        self.stdscr.keypad(1)\\n        curses.curs_set(0)\\n        self.snake = [(10, 10), (10, 9), (10, 8)]\\n        self.score = 0\\n        self.direction = curses.KEY_RIGHT\\n        self.spawn_food()\\n\\n    def spawn_food(self):\\n        while True:\\n            self.food = (random.randint(0, 20), random.randint(0, 20))\\n            if self.food not in self.snake:\\n                break\\n\\n    def draw(self):\\n        self.stdscr.clear()\\n        for x, y in self.snake:\\n            self.stdscr.addch(y, x, 'O')\\n        self.stdscr.addch(self.food[1], self.food[0], '*')\\n        self.stdscr.addstr(0, 0, f'Score: {self.score}')\\n        self.stdscr.refresh()\\n\\n    def move(self):\\n        new_head = (self.snake[0][0], self.snake[0][1])\\n        if self.direction == curses.KEY_UP:\\n            new_head = (new_head[0] - 1, new_head[1])\\n        elif self.direction == curses.KEY_DOWN:\\n            new_head = (new_head[0] + 1, new_head[1])\\n        elif self.direction == curses.KEY_LEFT:\\n            new_head = (new_head[0], new_head[1] - 1)\\n        elif self.direction == curses.KEY_RIGHT:\\n            new_head = (new_head[0], new_head[1] + 1)\\n\\n        self.snake.insert(0, new_head)\\n\\n        if self.snake[0] == self.food:\\n            self.score += 10\\n            self.spawn_food()\\n        else:\\n            self.snake.pop()\\n\\n        # Check collision with walls\\n        if new_head[0] < 0 or new_head[0] >= 22 or new_head[1] < 0 or new_head[1] >= 20:\\n            self.running = False\\n\\n        # Check collision with self\\n        if new_head in self.snake[1:]:\\n            self.running = False\\n\\n    def get_input(self):\\n        try:\\n            key = self.stdscr.getch()\\n            if key == ord('q'):\\n                self.running = False\\n            elif key == curses.KEY_UP and self.direction != curses.KEY_DOWN:\\n                self.direction = curses.KEY_UP\\n            elif key == curses.KEY_DOWN and self.direction != curses.KEY_UP:\\n                self.direction = curses.KEY_DOWN\\n            elif key == curses.KEY_LEFT and self.direction != curses.KEY_RIGHT:\\n                self.direction = curses.KEY_LEFT\\n            elif key == curses.KEY_RIGHT and self.direction != curses.KEY_LEFT:\\n                self.direction = curses.KEY_RIGHT\\n        except:\\n            pass\\n    def run(self):\\n        self.setup(self.stdscr)\\n        while self.running:\\n            self.draw()\\n            self.move()\\n            self.get_input()\\n            self.draw()\\n            curses.napms(100)\\n\\nif __name__ == '__main__':\\n    try:\\n        game = SnakeGame()\\n        game.run()\\n    except KeyboardInterrupt:\\n        print('Game Over!')\\n\",\"path\":\"Qwen3.5/snake.py\"}","detail":"Success: File 'Qwen3.5/snake.py' written (2979 bytes)."}
