{"format":"jsonl-v1","ts_ms":1775212608259,"pid":1,"mode":"Host","caller":"agent_text","transport":"text","tool_call_id":null,"tool_name":"write_file","success":true,"kill":false,"duration_ms":0,"cmd":"TOOL:write_file {\"content\":\"import pygame\\nimport sys\\nimport time\\nimport random\\n\\n# Direzioni\\nUP = 1\\nRIGHT = 2\\nDOWN = 3\\nLEFT = 4\\n\\nclass SnakeGame:\\n    def __init__(self, width=800, height=600):\\n        self.width = width\\n        self.height = height\\n        self.snake = [(200, 200), (220, 200), (240, 200)]\\n        self.direction = RIGHT\\n        self.apple = self.set_new_apple()\\n        self.score = 0\\n        self.speed = 10\\n        self.pause = False\\n\\n        pygame.init()\\n        self.display = pygame.display.set_mode((width, height))\\n        self.font = pygame.font.Font(None, 36)\\n        self.clock = pygame.time.Clock()\\n\\n    def set_new_apple(self):\\n        while True:\\n            x = random.randint(0, self.width - 20) // 20 * 20\\n            y = random.randint(0, self.height - 20) // 20 * 20\\n            if (x, y) not in self.snake:\\n                return (x, y)\\n\\n    def run(self):\\n        while True:\\n            for event in pygame.event.get():\\n                if event.type == pygame.QUIT:\\n                    pygame.quit()\\n                    sys.exit()\\n                elif event.type == pygame.KEYDOWN:\\n                    if event.key == pygame.K_UP and self.direction != DOWN:\\n                        self.direction = UP\\n                    elif event.key == pygame.K_DOWN and self.direction != UP:\\n                        self.direction = DOWN\\n                    elif event.key == pygame.K_LEFT and self.direction != RIGHT:\\n                        self.direction = LEFT\\n                    elif event.key == pygame.K_RIGHT and self.direction != LEFT:\\n                        self.direction = RIGHT\\n                    elif event.key == pygame.K_SPACE:\\n                        self.pause = not self.pause\\n\\n            if not self.pause:\\n                head = self.snake[-1]\\n                if self.direction == UP:\\n                    new_head = (head[0], head[1] - 20)\\n                elif self.direction == DOWN:\\n                    new_head = (head[0], head[1] + 20)\\n                elif self.direction == LEFT:\\n                    new_head = (head[0] - 20, head[1])\\n                elif self.direction == RIGHT:\\n                    new_head = (head[0] + 20, head[1])\\n\\n                self.snake.append(new_head)\\n                if self.apple == new_head:\\n                    self.apple = self.set_new_apple()\\n                    self.score += 1\\n                else:\\n                    self.snake.pop(0)\\n\\n                if (new_head[0] < 0 or new_head[0] >= self.width or\\n                        new_head[1] < 0 or new_head[1] >= self.height or\\n                        new_head in self.snake[:-1]):\\n                    print(\\\"Game Over! Your score is: \\\", self.score)\\n                    pygame.quit()\\n                    sys.exit()\\n\\n            self.display.fill((0, 0, 0))\\n            for pos in self.snake:\\n                pygame.draw.rect(self.display, (0, 255, 0), (pos[0], pos[1], 20, 20))\\n            pygame.draw.rect(self.display, (255, 0, 0), (self.apple[0], self.apple[1], 20, 20))\\n            text = self.font.render(f\\\"Score: {self.score}\\\", True, (255, 255, 255))\\n            self.display.blit(text, (10, 10))\\n            pygame.display.flip()\\n            self.clock.tick(self.speed)\\n\\nif __name__ == \\\"__main__\\\":\\n    game = SnakeGame()\\n    game.run()\",\"path\":\"Llama3.1/snake.py\"}","detail":"Success: File 'Llama3.1/snake.py' written (3259 bytes)."}
