{"format":"jsonl-v1","ts_ms":1775057211077,"pid":4,"mode":"Host","caller":"agent_text","transport":"text","tool_call_id":null,"tool_name":"read_file","success":true,"kill":false,"duration_ms":0,"cmd":"TOOL:read_file {\"path\":\"LLama3.1/snake.py\"}","detail":"import pygame\nimport sys\nimport time\nimport random\n\n# Direzioni\nUP = 1\nRIGHT = 2\nDOWN = 3\nLEFT = 4\n\nclass SnakeGame:\n    def __init__(self, width=800, height=600):\n        self.width = width\n        self.height = height\n        self.snake = [(200, 200), (220, 200), (240, 200)]\n        self.direction = RIGHT\n        self.apple = self.set_new_apple()\n        self.score = 0\n        self.game_over = False\n        pygame.init()\n        self.display = pygame.display.set_mode((self.width, self.height))\n        self.font = pygame.font.Font(None, 36)\n        self.clock = pygame.time.Clock()\n\n    def set_new_apple(self):\n        return (random.randint(0, self.width - 20) // 20 * 20, random.randint(0, self.height - 20) // 20 * 20)\n\n    def draw_snake(self):\n        for x, y in self.snake:\n            pygame.draw.rect(self.display, (0, 255, 0), (x, y, 20, 20))\n\n    def draw_apple(self):\n        pygame.draw.rect(self.display, (255, 0, 0), (*self.apple, 20, 20))\n\n    def update(self):\n        for event in pygame.event.get():\n            if event.type == pygame.QUIT:\n                pygame.quit()\n                sys.exit()\n            elif event.type == pygame.KEYDOWN:\n                if event.key == pygame.K_UP and self.direction != DOWN:\n                    self.direction = UP\n                elif event.key == pygame.K_DOWN and self.direction != UP:\n                    self.direction = DOWN\n                elif event.key == pygame.K_LEFT and self.direction != RIGHT:\n                    self.direction = LEFT\n                elif event.key == pygame.K_RIGHT and self.direction != LEFT:\n                    self.direction = RIGHT\n        head = self.snake[-1]\n        if self.direction == UP:\n            new_head = (head[0], head[1] - 20)\n        elif self.direction == DOWN:\n            new_head = (head[0], head[1] + 20)\n        elif self.direction == LEFT:\n            new_head = (head[0] - 20, head[1])\n        elif self.direction == RIGHT:\n            new_head = (head[0] + 20, head[1])\n        self.snake.append(new_head)\n        if self.snake[-1] == self.apple:\n            self.score += 1\n            self.apple = self.set_new_apple()\n        else:\n            self.snake.pop(0)\n        if (self.snake[-1][0] < 0 or self.snake[-1][0] >= self.width or\n            self.snake[-1][1] < 0 or self.snake[-1][1] >= self.height or\n            self.snake[-1] in self.snake[:-1]):\n            self.game_over = True\n\n    def draw(self):\n        self.display.fill((0, 0, 0))\n        self.draw_snake()\n        self.draw_apple()\n        text = self.font.render(f'Score: {self.score}', True, (255, 255, 255))\n        self.display.blit(text, (10, 10))\n        pygame.display.flip()\n\n    def run(self):\n        while not self.game_over:\n            self.update()\n            self.draw()\n            self.clock.tick(10)\n        pygame.quit()\n\nif __name__ == '__main__':\n    game = SnakeGame()\n    game.run()"}
