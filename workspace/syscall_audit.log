\\n    clock.tick(FPS)\\n\\nschermo.fill(BIANCO)\\ntesto_fine = font.render(f\\\"Game Over! Punteggio finale: {punteggio}\\\", True, NERO)\\nschermo.blit(testo_fine, (LARGHEZZA // 2 - testo_fine.get_width() // 2, ALTEZZA // 2))\\npygame.display.flip()\\npygame.time.wait(3000)\\npygame.quit()\\n\"}","detail":"pygame 2.6.1 (SDL 2.28.4, Python 3.12.3)\nHello from the pygame community. https://www.pygame.org/contribute.html\n"}
